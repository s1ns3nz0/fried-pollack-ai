# Path B environment overrides for reviewers deploying into their OWN Azure
# subscription. Copy to deploy/judge.env, fill in, then:  set -a; . deploy/judge.env; set +a
# before running scripts/deploy-red-with-sim.sh and scripts/bootstrap-red-agent.sh.

# --- Bicep parameter templates (fill the REPLACE_* tokens inside these files) ---
export RED_PARAM_FILE=infra/bicep/params/judge.bicepparam
export SIM_PARAM_FILE=infra/bicep/params/judge-sim.bicepparam
export BICEP_PARAM_FILE=infra/bicep/params/judge.bicepparam

# --- Your ACR (name = dahredacr<uniqueSuffix> from judge.bicepparam) ---
export RED_ACR_NAME=dahredacrREPLACE_UNIQUE_SUFFIX
export ACR_NAME=dahredacrREPLACE_UNIQUE_SUFFIX
export ACR_LOGIN_SERVER=dahredacrREPLACE_UNIQUE_SUFFIX.azurecr.io

# --- ToolServer image in YOUR ACR (built + pushed in step 4 of JUDGE-DEPLOY.md) ---
export TOOLSERVER_IMAGE=dahredacrREPLACE_UNIQUE_SUFFIX.azurecr.io/fried-pollack-ai:judge

# --- Your Azure OpenAI account (created in step 2) ---
export AZURE_OPENAI_RESOURCE_GROUP=REPLACE_YOUR_OPENAI_RESOURCE_GROUP
export AZURE_OPENAI_ACCOUNT_NAME=REPLACE_YOUR_OPENAI_ACCOUNT_NAME

# --- Region (must match the param files) ---
export LOCATION=koreacentral
